.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
}

.brand {
  text-align: center;
  margin-bottom: 80rpx;
}

.brand-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #e94560, #c23152);
  border-radius: 30rpx;
  color: #fff;
  font-size: 56rpx;
  font-weight: bold;
  line-height: 120rpx;
  margin: 0 auto 30rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 12rpx;
  margin-bottom: 16rpx;
}

.brand-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.features {
  width: 100%;
  margin-bottom: 80rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
}

.feature-icon {
  width: 10rpx;
  height: 10rpx;
  background: #e94560;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255,255,255,0.15);
  border: 2rpx solid rgba(255,255,255,0.3);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn:active {
  background: rgba(255,255,255,0.25);
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.note {
  margin-top: 40rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}
