<view class="page safe-bottom">
  <view class="page-header">
    <view class="title">创建营销任务</view>
  </view>

  <!-- 图片选择 -->
  <view class="card">
    <text class="form-label">选择照片（{{images.length}}/9）</text>
    <view class="image-grid">
      <view class="img-item" wx:for="{{images}}" wx:key="index">
        <image class="img-preview" src="{{item}}" mode="aspectFill"></image>
        <view class="img-remove" bindtap="removeImage" data-index="{{index}}">&#10005;</view>
      </view>
      <view class="img-add" wx:if="{{images.length < 9}}" bindtap="chooseImages">
        <view class="add-sign">+</view>
        <view class="add-label">添加图片</view>
      </view>
    </view>
  </view>

  <!-- 配置 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">目标平台</text>
      <view class="platform-row">
        <view class="platform-tag {{targets.wechat ? 'active' : ''}}"
              bindtap="toggleTarget" data-key="wechat">微信朋友圈</view>
        <view class="platform-tag {{targets.xiaohongshu ? 'active' : ''}}"
              bindtap="toggleTarget" data-key="xiaohongshu">小红书</view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">水印文字</text>
      <input class="form-input" placeholder="BIKON" value="{{watermarkText}}"
             bindinput="onWatermarkInput" maxlength="20"/>
    </view>

    <view class="form-group" style="margin-bottom:0">
      <text class="form-label">行业描述</text>
      <textarea class="form-textarea" placeholder="可留空，使用注册时填写的信息"
                value="{{industryContext}}" bindinput="onContextInput" maxlength="300"/>
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn btn-primary" bindtap="handleSubmit"
            loading="{{submitting}}" disabled="{{submitting || !images.length}}">
      {{submitting ? '生成中...' : '开始生成'}}
    </button>
  </view>
</view>
