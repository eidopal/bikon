.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 56rpx 80rpx;
  box-sizing: border-box;
}

.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  line-height: 140rpx;
  background: linear-gradient(135deg, #e94560, #f06292);
  border-radius: 36rpx;
  font-size: 64rpx;
  font-weight: 800;
  color: #fff;
  margin: 0 auto 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(233,69,96,0.35);
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 16rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 16rpx;
}

.features {
  width: 100%;
  margin-bottom: 80rpx;
  padding: 0 20rpx;
}

.feat-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.feat-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(233,69,96,0.7);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feat-item text {
  color: rgba(255,255,255,0.75);
  font-size: 26rpx;
  line-height: 1.5;
}

.btn-area {
  width: 100%;
  text-align: center;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
}

.agreement {
  margin-top: 32rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}
