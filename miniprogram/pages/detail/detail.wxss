.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.status-bar {
  padding: 24rpx 30rpx;
  text-align: center;
}

.status-PENDING, .status-PROCESSING { background: #e3f2fd; }
.status-COMPLETED { background: #e8f5e9; }
.status-FAILED { background: #ffebee; }

.status-text {
  font-size: 28rpx;
  font-weight: bold;
}

.status-PENDING .status-text, .status-PROCESSING .status-text { color: #1565c0; }
.status-COMPLETED .status-text { color: #2e7d32; }
.status-FAILED .status-text { color: #c62828; }

.loading-area {
  padding: 120rpx 40rpx;
  text-align: center;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #e94560;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #999;
}

.platform-label {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.wechat { background: #e8f5e9; color: #2e7d32; }
.xhs { background: #fce4ec; color: #c62828; }

.copy-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
  margin-bottom: 20rpx;
}

.tags {
  margin-bottom: 20rpx;
}

.hash-tag {
  display: inline-block;
  color: #e94560;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.copy-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0;
}

.result-images {
  display: flex;
  flex-wrap: wrap;
}

.result-img {
  width: 210rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
}

.result-img:nth-child(3n) {
  margin-right: 0;
}

.error-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.retry-area {
  padding: 40rpx 20rpx;
}
