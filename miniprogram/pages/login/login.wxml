<view class="login-page">
  <view class="brand">
    <view class="brand-icon">B</view>
    <view class="brand-name">BIKON</view>
    <view class="brand-desc">AI 驱动的营销内容生产线</view>
  </view>

  <view class="features">
    <view class="feature-item">
      <view class="feature-icon"></view>
      <text>上传服务照片，自动生成精美水印图</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon"></view>
      <text>智能生成朋友圈+小红书多平台文案</text>
    </view>
    <view class="feature-item">
      <view class="feature-icon"></view>
      <text>一键复制发布，省时省力</text>
    </view>
  </view>

  <button class="login-btn" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
    微信一键登录
  </button>

  <view class="note">登录即表示同意《用户服务协议》</view>
</view>
