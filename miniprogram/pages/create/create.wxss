.page {
  min-height: 100vh;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.img-item {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.img-preview {
  width: 100%;
  height: 100%;
}

.img-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: rgba(0,0,0,0.45);
  color: #fff;
  font-size: 24rpx;
  border-radius: 0 14rpx 0 14rpx;
}

.img-add {
  width: 152rpx;
  height: 152rpx;
  border: 2rpx dashed #d0d0d0;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  box-sizing: border-box;
}

.add-sign {
  font-size: 52rpx;
  color: #ccc;
  line-height: 1;
}

.add-label {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 6rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.platform-row {
  display: flex;
  gap: 16rpx;
}

.platform-tag {
  padding: 14rpx 36rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.platform-tag.active {
  background: rgba(233,69,96,0.08);
  color: var(--red);
  font-weight: 600;
}

.btn-wrap {
  padding: 8rpx 24rpx 40rpx;
}
