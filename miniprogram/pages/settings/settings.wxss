.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.asset-list {
  margin-bottom: 20rpx;
}

.asset-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.asset-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.asset-info {
  flex: 1;
  font-size: 26rpx;
}

.asset-name {
  color: #999;
  font-size: 22rpx;
}

.logout-btn {
  width: 100%;
  color: #999;
  font-size: 26rpx;
  background: none;
  border: none;
  padding: 10rpx 0;
}
