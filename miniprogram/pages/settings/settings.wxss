.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.btn-wrap {
  padding: 8rpx 24rpx 24rpx;
}

.asset-list {
  margin-bottom: 20rpx;
}

.asset-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.asset-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 10rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.asset-info {
  flex: 1;
  font-size: 26rpx;
}

.logout-btn {
  width: 100%;
  color: var(--text-muted);
  border: none;
  background: none;
}
