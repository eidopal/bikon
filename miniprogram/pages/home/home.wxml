<view class="page safe-bottom">
  <view class="topbar">
    <view class="topbar-left">
      <view class="topbar-name">{{merchantName || 'BIKON'}}</view>
    </view>
    <view class="topbar-right" bindtap="goSettings">
      <text class="topbar-icon">&#9881;</text>
    </view>
  </view>

  <view class="stats">
    <view class="stat">
      <view class="stat-num">{{monthCount}}</view>
      <view class="stat-label">本月任务</view>
    </view>
    <view class="stat">
      <view class="stat-num">{{todayCount}}</view>
      <view class="stat-label">今日提交</view>
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn btn-primary" bindtap="goCreate">创建营销任务</button>
  </view>

  <view class="section" wx:if="{{recentTasks.length}}">
    <view class="section-head">
      <text class="section-title">最近任务</text>
      <text class="section-more" bindtap="goTasks">查看全部</text>
    </view>
    <view class="task-item" wx:for="{{recentTasks}}" wx:key="task_id"
          bindtap="goDetail" data-id="{{item.task_id}}">
      <view class="task-left">
        <view class="task-id-text">任务 #{{item.task_id.split('_')[1] || item.task_id}}</view>
        <view class="task-time">{{item.created_at || ''}}</view>
      </view>
      <view class="tag tag-{{item.status}}">{{statusText[item.status] || item.status}}</view>
    </view>
  </view>

  <view class="empty" wx:if="{{!recentTasks.length && !loading}}">
    <view class="empty-icon">&#128203;</view>
    <view>还没有任务</view>
    <view class="caption">点击上方按钮创建第一个</view>
  </view>
</view>
