/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
}

/* 品牌色 */
.primary-color { color: #e94560; }
.primary-bg { background: #e94560; }

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  text-align: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: #fff;
  color: #e94560;
  border: 2rpx solid #e94560;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  box-sizing: border-box;
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-pending { background: #fff3e0; color: #e65100; }
.tag-processing { background: #e3f2fd; color: #1565c0; }
.tag-completed { background: #e8f5e9; color: #2e7d32; }
.tag-failed { background: #ffebee; color: #c62828; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}
