.page {
  min-height: 100vh;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--white);
}

.topbar-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.topbar-icon {
  font-size: 36rpx;
  color: var(--text-muted);
}

.stats {
  display: flex;
  margin: 24rpx;
}

.stat {
  flex: 1;
  padding: 32rpx;
  background: var(--white);
  border-radius: 20rpx;
  text-align: center;
}

.stat:first-child {
  margin-right: 16rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--red);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.btn-wrap {
  padding: 0 24rpx 24rpx;
}

.section {
  padding: 0 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-more {
  font-size: 24rpx;
  color: var(--red);
}

.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--white);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.task-left {
  flex: 1;
}

.task-id-text {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.task-time {
  font-size: 22rpx;
  color: var(--text-muted);
}
