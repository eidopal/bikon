<view class="page">
  <!-- 图片选择区域 -->
  <view class="card">
    <view class="form-label">选择服务照片（最多9张）</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill"></image>
        <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="image-item add-btn" wx:if="{{images.length < 9}}" bindtap="chooseImages">
        <text class="add-icon">+</text>
        <text class="add-text">添加</text>
      </view>
    </view>
  </view>

  <!-- 配置选项 -->
  <view class="card">
    <view class="form-group">
      <text class="form-label">目标平台</text>
      <view class="check-row">
        <view class="check-item {{targets.wechat ? 'checked' : ''}}" bindtap="toggleTarget" data-key="wechat">
          微信朋友圈
        </view>
        <view class="check-item {{targets.xiaohongshu ? 'checked' : ''}}" bindtap="toggleTarget" data-key="xiaohongshu">
          小红书
        </view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">水印文字</text>
      <input class="form-input" placeholder="默认：BIKON" value="{{watermarkText}}" bindinput="onWatermarkInput" maxlength="20"/>
    </view>

    <view class="form-group">
      <text class="form-label">门店描述</text>
      <textarea class="form-textarea" placeholder="可选，覆盖注册时填写的行业描述" value="{{industryContext}}" bindinput="onContextInput" maxlength="300"/>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button class="btn-primary" bindtap="handleSubmit" loading="{{submitting}}" disabled="{{submitting || !images.length}}">
      {{submitting ? '上传生成中...' : '开始生成'}}
    </button>
    <view class="tip" wx:if="{{!submitting}}">预计等待 10-15 秒</view>
  </view>
</view>
