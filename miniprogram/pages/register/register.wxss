.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.header {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
}

.header-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

.card {
  margin: 30rpx 20rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  line-height: 48rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 180rpx;
  box-sizing: border-box;
}

.submit-area {
  padding: 20rpx 20rpx;
}
