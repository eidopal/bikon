.page {
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: var(--white);
  padding: 0 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: var(--text-muted);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab.active {
  color: var(--red);
  border-bottom-color: var(--red);
  font-weight: 600;
}

.task-list {
  padding: 24rpx;
}

.task-card {
  background: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.task-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.task-label {
  font-size: 28rpx;
  font-weight: 500;
}

.task-bottom {
  font-size: 22rpx;
  color: var(--text-muted);
}

.more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}
