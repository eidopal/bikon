/* ====== BIKON Design System ====== */

page {
  --red: #e94560;
  --red-dark: #c23152;
  --text: #1a1a2e;
  --text-secondary: #666;
  --text-muted: #999;
  --bg: #f5f6f8;
  --white: #fff;
  --border: #eee;

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
  box-sizing: border-box;
}

/* ====== Typography ====== */
.h1 { font-size: 40rpx; font-weight: 700; }
.h2 { font-size: 34rpx; font-weight: 600; }
.h3 { font-size: 30rpx; font-weight: 600; }
.body { font-size: 28rpx; color: #333; }
.caption { font-size: 24rpx; color: var(--text-muted); }

/* ====== Card ====== */
.card {
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  background: var(--white);
  border-radius: 20rpx;
}

/* ====== Buttons ====== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, var(--red), var(--red-dark));
  color: #fff;
}

.btn-outline {
  background: var(--white);
  color: var(--red);
  border: 2rpx solid var(--red);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  height: 72rpx;
  font-size: 26rpx;
}

.btn-sm {
  height: 60rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  color: #333;
  border: none;
}

/* ====== Form ====== */
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #f5f6f8;
  border-radius: 14rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  background: #f5f6f8;
  border-radius: 14rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

/* ====== Status Tags ====== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-pending    { background: #fff3e0; color: #e65100; }
.tag-processing { background: #e3f2fd; color: #1565c0; }
.tag-completed  { background: #e8f5e9; color: #2e7d32; }
.tag-failed     { background: #ffebee; color: #c62828; }

/* ====== Empty State ====== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* ====== Page Header ====== */
.page-header {
  padding: 40rpx 24rpx 20rpx;
}

.page-header .title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.page-header .subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* ====== Divider ====== */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 0 24rpx;
}

/* ====== Safe Area ====== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
