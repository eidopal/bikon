.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Status bar */
.status {
  padding: 20rpx 32rpx;
  text-align: center;
}

.status-PENDING,
.status-PROCESSING { background: #e3f2fd; color: #1565c0; }
.status-COMPLETED    { background: #e8f5e9; color: #2e7d32; }
.status-FAILED       { background: #ffebee; color: #c62828; }

.status-text {
  font-size: 28rpx;
  font-weight: 600;
}

/* Loading */
.loading-block {
  padding: 120rpx 40rpx;
  text-align: center;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #eee;
  border-top-color: var(--red);
  border-radius: 50%;
  margin: 0 auto 32rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Platform label */
.platform-label {
  display: inline-block;
  padding: 4rpx 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.label-xhs { background: #fce4ec; color: #c62828; }
.label-wx  { background: #e8f5e9; color: #2e7d32; }

/* Copy text */
.copy-body {
  font-size: 30rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 16rpx;
}

.tags-row {
  margin-bottom: 16rpx;
}

.hash {
  display: inline-block;
  color: var(--red);
  font-size: 24rpx;
  margin-right: 14rpx;
  margin-bottom: 8rpx;
}

/* Image grid */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.img-wrap {
  width: 212rpx;
}

.img-thumb {
  width: 100%;
  border-radius: 10rpx;
  display: block;
}

.img-btns {
  margin-top: 8rpx;
}

.save-btn {
  width: 100%;
  box-sizing: border-box;
}

.save-all {
  width: 100%;
  height: 72rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
}

/* Guide */
.guide-box {
  border-left: 6rpx solid var(--red);
}

.guide-label {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.guide-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.guide-num {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 50%;
  background: var(--red);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.guide-content {
  flex: 1;
}

.guide-title {
  font-size: 28rpx;
  font-weight: 600;
}

.guide-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 2rpx;
}

.guide-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* Retry */
.btn-wrap {
  padding: 32rpx 24rpx;
}
